# 阿里云百炼API配置
DASHSCOPE_API_KEY=sk-your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Redis配置
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# 服务配置
ANSWER_SERVICE_PORT=8000
VIZ_SERVICE_PORT=8001
VIZ_SERVICE_URL=http://viz-service:8001
VIZ_SERVICE_BASE_URL=http://localhost:8000

# 执行限制
MAX_EXECUTION_TIME=30
MAX_MEMORY_MB=512
MAX_CODE_LENGTH=10000

# 日志级别
LOG_LEVEL=INFO

# 环境
ENVIRONMENT=development

# 缓存配置
CACHE_TTL=3600
TEXT_ANSWER_RETRY=3
TEXT_ANSWER_TIMEOUT=30
LLM_SYNC_TIMEOUT=90

# 可视化配置
VIZ_TIMEOUT=15
ENABLE_VISUALIZATION=true 